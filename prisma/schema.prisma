// File: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model untuk Santri Aktif (dari API + input manual admin)
model Santri {
  id              String   @id @default(cuid())
  nama            String
  nis             String   @unique
  gender          String?  // PUTRA | PUTRI
  asrama          String?
  provinsi        String?
  kabupaten       String?
  kecamatan       String?
  desa            String?
  namaAyah        String?
  namaIbu         String?
  noHpOrangTua    String?
  kelasFormal     String?
  kelasNgaji      String?  // Diambil dari field 'activeClass' di API
  ttl             String?
  tahunMasuk      Int?     // Diisi otomatis dari NIS, bisa diubah admin
  leadershipName  String?  // Nama kepengurusan (misal: NALAR ATI DAN JURNALISTIK)
  leadershipStatus String? // Jabatan: MEMBER | KETUA dll
  status          String   @default("AKTIF")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Model untuk Alumni (semua diinput manual oleh admin)
model Alumni {
  id                String   @id @default(cuid())
  nama              String
  gender            String?  // PUTRA | PUTRI

  // Alamat Asli (terstruktur, mengikuti model Santri)
  provinsiAsli      String?
  kabupatenAsli     String?
  kecamatanAsli     String?
  desaAsli          String?

  // Alamat Domisili (terstruktur)
  provinsiDomisili   String?
  kabupatenDomisili  String?
  kecamatanDomisili  String?
  desaDomisili       String?

  // Detail tambahan
  detailAlamat      String?  // RT/RW, nama jalan, dll

  // Data lain
  tahunMasuk        Int?
  tahunKeluar       Int?
  angkatanAmtsilati Int?
  noHp              String?  @unique
  status            String   @default("PENDING") // PENDING | APPROVED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}